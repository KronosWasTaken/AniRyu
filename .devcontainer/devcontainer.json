{
  "name": "AniRyu Full Stack",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "pnpmVersion": "latest"
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.21"
    },
    "ghcr.io/devcontainers/features/common-utils:1": {
      "configureZsh": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "golang.Go",
        "bradlc.vscode-tailwindcss",
        "formulahendry.auto-rename-tag"
      ]
    }
  },
  "mounts": [
    "source=aniryu-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
    "source=aniryu-pnpm-store,target=/home/vscode/.local/share/pnpm/store,type=volume",
    "source=aniryu-go-cache,target=/home/vscode/.cache/go-build,type=volume",
    "source=aniryu-go-mod,target=/home/vscode/go/pkg/mod,type=volume"
  ],
  "forwardPorts": [3000, 3001, 5173],
  "postCreateCommand": "echo '--- Dev Container Startup Started ---' && echo 'Checking pnpm version:' && pnpm --version && echo 'Installing NodeJS dependencies...' && pnpm install && echo 'Installing Go dependencies...' && cd backend && go mod download && echo '--- Dev Container Startup Finished ---'",
  "remoteUser": "vscode"
}
